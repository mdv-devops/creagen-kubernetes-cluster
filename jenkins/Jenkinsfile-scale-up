pipeline {
    agent {
        kubernetes {
            yamlFile 'jenkins/builder.yaml'
            defaultContainer 'terraform'
        }
    }

    environment {
        HCLOUD_TOKEN = credentials('CREAGEN_HCLOUD_TOKEN')

        AWS_ACCESS_KEY_ID     = credentials('REMOTE_STATE_AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('REMOTE_STATE_AWS_SECRET_ACCESS_KEY')

        AWS_DEFAULT_REGION = 'us-east-1'
    }

    options {
        disableConcurrentBuilds()
        ansiColor('xterm')
    }

    stages {
        stage('Scale Up') {
            steps {
                container('terraform') {
                    lock(resource: 'terraform-creagen-autoscaler') {
                        sshagent(credentials: ['github-ssh']) {
                            withCredentials([
                                file(credentialsId: 'CREAGEN_KUBECONFIG', variable: 'KUBECONFIG')
                            ]) {
                                sh 'chmod +x scripts/scale-up.sh'
                                sh './scripts/scale-up.sh'
                            }
                        }
                    }
                }
            }
        }
    }
}
